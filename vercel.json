{
  "version": 2,
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/.next",
  "env": {
    "NEXT_PUBLIC_API_URL": {
      "description": "API endpoint for frontend",
      "default": "https://api.yourdomain.com"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/",
      "status": 404,
      "continue": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
